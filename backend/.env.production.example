# Server Configuration
PORT=3000
NODE_ENV=production
PUBLIC_BASE_URL="https://api.smartdoor.example.com"

# MongoDB Connection
# Recommended: use MongoDB Atlas or another managed MongoDB service
DATABASE_URL="mongodb+srv://<username>:<password>@cluster.mongodb.net/smartdoor_prod?retryWrites=true&w=majority"

# JWT Configuration
# Use a long random value in production (at least 32 characters)
JWT_SECRET="replace-this-with-a-long-random-secret"
JWT_ACCESS_TOKEN_EXPIRY="15m"
JWT_REFRESH_TOKEN_EXPIRY="7d"

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# CORS
# Comma-separated list for your mobile/web origins, or "*" during private testing
CORS_ORIGIN="*"
