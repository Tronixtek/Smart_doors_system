# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Connection
# Local MongoDB: mongodb://localhost:27017/hotel_management
# MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/hotel_management?retryWrites=true&w=majority
DATABASE_URL="mongodb://localhost:27017/hotel_management"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-characters"
JWT_ACCESS_TOKEN_EXPIRY="15m"
JWT_REFRESH_TOKEN_EXPIRY="7d"

# Security
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# CORS
CORS_ORIGIN="*"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
